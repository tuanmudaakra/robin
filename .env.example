# Robin runtime config (contoh). Salin ke .env dan isi nilai asli.
# .env akan meng-override config/config.json.

# --- API keys ---
HELIUS_API_KEY=
BIRDEYE_API_KEY=
RPC_URL=https://mainnet.helius-rpc.com/?api-key=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_SIGNAL_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# --- LLM (opsional; kalau kosong Robin jalan 100% rule-based) ---
# Kompatibel OpenAI-chat: freemodel.dev / DeepSeek / OpenRouter / OpenAI
# tinggal ganti base_url + model + api_key di bawah.
LLM_ENABLED=false

# == freemodel.dev (Claude — Anthropic native format) ==
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api-cc.freemodel.dev
# LLM_API_KEY=<api key dari dashboard freemodel.dev>
# LLM_MODEL=claude-sonnet-4-6

# == DeepSeek (default) ==
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# == OpenRouter (banyak pilihan model) ==
# LLM_BASE_URL=https://openrouter.ai/api
# LLM_API_KEY=<openrouter key>
# LLM_MODEL=anthropic/claude-3.5-sonnet
